---
const year = new Date().getFullYear();
---
<footer id="contact" class="bg-surface border-t border-line py-16 px-6">
  <div class="max-w-3xl mx-auto">
    <h2 class="font-display text-3xl sm:text-4xl font-bold text-ink mb-4">Contact</h2>
    <p class="font-body text-muted mb-10">
      I'm always open to discussing new opportunities. Feel free to reach out!
    </p>
    <div class="flex items-center gap-8 mb-16">
      <a
        href="mailto:will@willmoppel.com"
        aria-label="Email will@willmoppel.com"
        class="text-muted hover:text-accent transition-colors"
      >
        <!-- Email / envelope -->
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="w-8 h-8"
          aria-hidden="true"
        >
          <path d="M1.5 8.67v8.58a3 3 0 003 3h15a3 3 0 003-3V8.67l-8.928 5.493a3 3 0 01-3.144 0L1.5 8.67z" />
          <path d="M22.5 6.908V6.75a3 3 0 00-3-3h-15a3 3 0 00-3 3v.158l9.714 5.978a1.5 1.5 0 001.572 0L22.5 6.908z" />
        </svg>
      </a>

      <a
        href="https://www.linkedin.com/in/will-moppel-e197/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn profile"
        class="text-muted hover:text-accent transition-colors"
      >
        <!-- LinkedIn logo -->
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="w-8 h-8"
          aria-hidden="true"
        >
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
        </svg>
      </a>

      <a
        href="https://github.com/wmoppel"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub profile"
        class="text-muted hover:text-accent transition-colors"
      >
        <!-- GitHub mark -->
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="w-8 h-8"
          aria-hidden="true"
        >
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z" />
        </svg>
      </a>

      <a
        href="https://drive.google.com/file/d/1yhzxYskU06-UfW7l6zp6oHhuBVo87-Tz/view?usp=sharing"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Resume (PDF)"
        class="text-muted hover:text-accent transition-colors"
      >
        <!-- Resume / document icon -->
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="w-8 h-8"
          aria-hidden="true"
        >
          <path d="M6 2h7l5 5v13a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2z" />
          <path d="M13 2v5h5" opacity=".9" />
          <path d="M8 13h8v2H8zm0-4h8v2H8z" />
        </svg>
      </a>
    </div>
    <p class="font-body text-xs text-muted border-t border-line pt-6">
      &copy; {year} Will Moppel. All rights reserved.
    </p>
  </div>
</footer>
