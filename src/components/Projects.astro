---
import ProjectCard from "./ProjectCard.astro";

// TODO: Replace DUNGEON_BRAWL_COVER with a real imported cover image once available.
// When ready: import dungeonBrawlCover from "../assets/dungeon-brawl/cover.png";
// Then pass  cover={dungeonBrawlCover.src}  (or use Astro's <Image /> inside ProjectCard).
// Real cover images must live in src/assets/ — NOT /public/ — for Astro optimisation.
const _dbSvg =
  '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1600 900">' +
  '<rect width="1600" height="900" fill="#121a2e"/>' +
  '<rect x="3" y="3" width="1594" height="894" fill="none" stroke="#243149" stroke-width="6"/>' +
  '<text x="800" y="450" font-family="Space Grotesk Variable,sans-serif" font-size="48" fill="#93a0bd" text-anchor="middle" dominant-baseline="middle">Dungeon Brawl</text>' +
  "</svg>";
const DUNGEON_BRAWL_COVER = "data:image/svg+xml," + encodeURIComponent(_dbSvg);
---
<!-- TODO: Expand this section in a later step with game and Blender project showcases
     (video embeds + image galleries). Keep the id="projects" anchor in place. -->
<section id="projects" class="py-20 px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="font-display text-3xl sm:text-4xl font-bold text-ink mb-4">Projects</h2>
    <p class="font-body text-muted mb-12">
      Some of my current and past projects!
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <ProjectCard
        title="The Circle of Life"
        blurb="Solve puzzles by working with past versions of yourself."
        cover="/TCOLSS.png"
        href="/games/the-circle-of-life"
        tags={["Unreal Engine", "Puzzle Platformer"]}
      />
      <ProjectCard
        title="Dungeon Brawl"
        blurb="Fight with friends in this arena style action platformer!"
        cover={DUNGEON_BRAWL_COVER}
        href="/games/dungeon-brawl"
        tags={["Unreal Engine", "Action Platformer"]}
      />
    </div>
  </div>
</section>
