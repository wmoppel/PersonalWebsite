---
const skillGroups = [
  {
    category: "Game Development & 3D",
    skills: [
      "Unreal Engine",
      "Unity",
      "Blender (3D Modeling)",
      "PC / Linux / VR Packaging",
    ],
  },
  {
    category: "Languages",
    skills: ["C++", "Python", "Java", "TypeScript", "SQL (PostgreSQL)", "Bash"],
  },
  {
    category: "Backend & Cloud",
    skills: ["FastAPI", "REST APIs", "Docker", "Kubernetes", "Firebase", "Cloudflare", "SQLAlchemy"],
  },
  {
    category: "Engineering & Tools",
    skills: [
      "Git",
      "CI/CD",
      "Unit Testing",
      "Astro",
      "Tailwind CSS",
      "Agile / Scrum",
      "Adobe Creative Cloud",
      "GitHub Copilot",
    ],
  },
];
---

<section id="skills" class="py-20 px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="font-display text-3xl sm:text-4xl font-bold text-ink mb-12">Skills</h2>
    <div class="grid gap-6 sm:grid-cols-2">
      {skillGroups.map((group) => (
        <div class="bg-surface rounded-xl p-6 border border-line">
          <h3 class="font-display font-semibold text-accent mb-4">{group.category}</h3>
          <ul class="flex flex-wrap gap-2 list-none p-0 m-0">
            {group.skills.map((skill) => (
              <li class="font-body text-xs text-muted bg-surface-2 border border-line rounded px-3 py-1">
                {skill}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
