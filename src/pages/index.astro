---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Will Moppel — Game Developer">
  <main class="min-h-screen flex flex-col items-center justify-center px-6 text-center">
    <p class="font-body text-accent text-sm uppercase tracking-[0.2em] mb-4">
      Game Developer · CS @ UNC
    </p>
    <h1 class="font-display text-5xl sm:text-7xl font-bold text-ink mb-6">
      Will Moppel
    </h1>
    <p class="font-body text-muted text-lg max-w-xl">
      Building worlds in Unreal Engine and Blender.
    </p>
  </main>
</BaseLayout>