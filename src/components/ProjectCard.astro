---
interface Props {
  title: string;
  blurb: string;
  cover: string;
  href: string;
  tags?: string[];
}

const { title, blurb, cover, href, tags = [] } = Astro.props;
---

<a
  href={href}
  class="group block bg-surface border border-line rounded-xl overflow-hidden hover:border-accent hover:-translate-y-1 transition-all duration-200"
>
  <div class="aspect-video overflow-hidden bg-surface-2">
    <img
      src={cover}
      alt={`${title} cover`}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
      loading="lazy"
    />
  </div>
  <div class="p-6">
    <h3 class="font-display font-bold text-lg text-ink mb-2">{title}</h3>
    <p class="font-body text-sm text-muted mb-4">{blurb}</p>
    {
      tags.length > 0 && (
        <ul class="flex flex-wrap gap-2 list-none p-0 m-0">
          {tags.map((tag) => (
            <li class="font-body text-xs text-muted bg-surface-2 border border-line rounded px-3 py-1">
              {tag}
            </li>
          ))}
        </ul>
      )
    }
  </div>
</a>
