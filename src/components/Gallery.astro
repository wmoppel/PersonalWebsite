---
import type { ImageMetadata } from "astro";
// TODO: Uncomment both imports below when wiring up real screenshots:
// import { Image } from "astro:assets";
// import { getImage } from "astro:assets";

interface GalleryImage {
  src: ImageMetadata;
  alt: string;
  caption?: string;
}

interface Props {
  images?: GalleryImage[];
  placeholderCount?: number;
  columns?: number;
}

const { images = [], placeholderCount = 6, columns = 3 } = Astro.props;

// Themed 16:9 SVG tile: bg-surface fill, border-line border, muted "Screenshot N" label in font-display.
// Zero network requests — generated as an inline data URI.
function makePlaceholderSvg(n: number): string {
  const s =
    '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1600 900">' +
    '<rect width="1600" height="900" fill="#121a2e"/>' +
    '<rect x="3" y="3" width="1594" height="894" fill="none" stroke="#243149" stroke-width="6"/>' +
    `<text x="800" y="450" font-family="Space Grotesk Variable,sans-serif" font-size="48" fill="#93a0bd" text-anchor="middle" dominant-baseline="middle">Screenshot ${n}</text>` +
    "</svg>";
  return "data:image/svg+xml," + encodeURIComponent(s);
}

// ---------------------------------------------------------------------------
// TODO: When real screenshots are ready, replace the `items` assignment below
// with the following block (and uncomment the astro:assets imports above):
//
//   const items = await Promise.all(
//     images.map(async ({ src, alt, caption }) => {
//       // Optimised 640×360 thumbnail — lazy-loaded in the grid
//       const thumb = await getImage({ src, width: 640, height: 360, format: "webp", quality: 80 });
//       // Optimised full image (≤1600px wide) — loaded lazily only when the lightbox opens
//       const full  = await getImage({ src, width: 1600, format: "webp", quality: 85 });
//       return { thumbSrc: thumb.src, fullSrc: full.src, alt, caption };
//     })
//   );
//
// Then in the thumbnail grid, swap the <img> placeholder tag for:
//   <Image src={originalImageMetadata} alt={item.alt} width={640} height={360}
//          loading="lazy" decoding="async" class="w-full h-full object-cover ..." />
//
// Rules:
//  • Real screenshots must live in src/assets/ — never /public/ — for Astro optimisation.
//  • Never load full-size images until the lightbox opens (data-full is read lazily by the JS).
// ---------------------------------------------------------------------------

type Item = { thumbSrc: string; fullSrc: string; alt: string; caption: string | undefined };

// TODO: Replace this placeholder array once real screenshots exist (see block above)
const items: Item[] = images.length === 0
  ? Array.from({ length: placeholderCount }, (_, i) => {
      const uri = makePlaceholderSvg(i + 1);
      return { thumbSrc: uri, fullSrc: uri, alt: `Screenshot ${i + 1}`, caption: undefined };
    })
  : []; // images provided but real-image processing not yet implemented — follow the TODO above

// All grid class strings must appear literally in source so Tailwind v4's scanner picks them up.
const gridClass =
  columns === 1 ? "grid-cols-1" :
  columns === 2 ? "grid-cols-1 sm:grid-cols-2" :
  columns === 4 ? "grid-cols-1 sm:grid-cols-2 lg:grid-cols-4" :
  /* default 3 */ "grid-cols-1 sm:grid-cols-3";
---

<div class="gallery" data-gallery>

  <!-- Thumbnail grid -->
  <div class={`grid ${gridClass} gap-4`}>
    {items.map((item, i) => (
      <button
        type="button"
        data-thumb
        data-index={String(i)}
        data-full={item.fullSrc}
        data-alt={item.alt}
        data-caption={item.caption ?? ""}
        aria-label={`View screenshot ${i + 1}${item.caption ? ": " + item.caption : ""}`}
        class="group w-full aspect-video overflow-hidden rounded-lg border border-line hover:border-accent focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-base transition-colors motion-reduce:transition-none cursor-pointer bg-surface-2"
      >
        {/* TODO: Replace this <img> with an Astro <Image /> component when real screenshots exist.
            See the detailed swap instructions in the TODO comment block at the top of this file. */}
        <img
          src={item.thumbSrc}
          alt={item.alt}
          width="640"
          height="360"
          loading="lazy"
          decoding="async"
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300 motion-reduce:transition-none"
        />
      </button>
    ))}
  </div>

  <!-- ================================================================
       LIGHTBOX OVERLAY
       Hidden via inline style until a thumbnail is clicked.
       Scoped to this gallery root via data-* attributes so multiple
       Gallery instances on one page work independently.
       ================================================================ -->
  <div
    data-lightbox
    role="dialog"
    aria-modal="true"
    aria-label="Screenshot viewer"
    aria-hidden="true"
    style="display: none;"
    class="fixed inset-0 z-50 p-4 items-center justify-center"
  >
    <!-- Backdrop — click to close; sits behind the content panel -->
    <div
      data-lb-backdrop
      class="absolute inset-0 bg-base/90 backdrop-blur-sm"
      aria-hidden="true"
    ></div>

    <!-- Content panel -->
    <div class="relative z-10 flex flex-col gap-3 max-w-5xl w-full mx-auto">

      <!-- Top bar: position counter + close button -->
      <div class="flex items-center justify-between">
        <span
          data-lb-counter
          class="font-body text-xs text-muted tabular-nums select-none"
          aria-live="polite"
          aria-atomic="true"
        ></span>
        <button
          type="button"
          data-lb-close
          aria-label="Close screenshot viewer"
          class="font-display font-bold text-2xl leading-none text-muted hover:text-ink focus:outline-none focus:ring-2 focus:ring-accent rounded px-2 py-1 transition-colors motion-reduce:transition-none"
        >
          <span aria-hidden="true">×</span>
        </button>
      </div>

      <!-- Image row: prev — image — next -->
      <div class="flex items-center gap-3">
        <button
          type="button"
          data-lb-prev
          aria-label="Previous screenshot"
          class="shrink-0 font-display text-4xl leading-none text-muted hover:text-ink focus:outline-none focus:ring-2 focus:ring-accent rounded px-3 py-2 transition-colors motion-reduce:transition-none disabled:opacity-25 disabled:cursor-not-allowed"
        >
          <span aria-hidden="true">‹</span>
        </button>

        <div class="flex-1 flex justify-center overflow-hidden">
          <!-- Full-size image; src is set lazily by JS only when the lightbox opens -->
          <img
            data-lb-img
            src=""
            alt=""
            class="max-w-full max-h-[75vh] rounded-lg object-contain"
          />
        </div>

        <button
          type="button"
          data-lb-next
          aria-label="Next screenshot"
          class="shrink-0 font-display text-4xl leading-none text-muted hover:text-ink focus:outline-none focus:ring-2 focus:ring-accent rounded px-3 py-2 transition-colors motion-reduce:transition-none disabled:opacity-25 disabled:cursor-not-allowed"
        >
          <span aria-hidden="true">›</span>
        </button>
      </div>

      <!-- Optional caption -->
      <p
        data-lb-caption
        hidden
        class="font-body text-sm text-muted text-center"
      ></p>

    </div>
  </div>

</div>

<script>
  // Runs once; handles every [data-gallery] on the page independently.
  // No libraries — pure vanilla JS, minimal footprint.
  document.querySelectorAll<HTMLElement>("[data-gallery]").forEach((gallery) => {
    const thumbBtns = Array.from(
      gallery.querySelectorAll<HTMLButtonElement>("[data-thumb]")
    );
    const dialog    = gallery.querySelector<HTMLElement>("[data-lightbox]")!;
    const imgEl     = dialog.querySelector<HTMLImageElement>("[data-lb-img]")!;
    const captEl    = dialog.querySelector<HTMLElement>("[data-lb-caption]")!;
    const counterEl = dialog.querySelector<HTMLElement>("[data-lb-counter]")!;
    const closeBtn  = dialog.querySelector<HTMLButtonElement>("[data-lb-close]")!;
    const prevBtn   = dialog.querySelector<HTMLButtonElement>("[data-lb-prev]")!;
    const nextBtn   = dialog.querySelector<HTMLButtonElement>("[data-lb-next]")!;
    const backdrop  = dialog.querySelector<HTMLElement>("[data-lb-backdrop]")!;

    let current = -1;
    let opener: HTMLButtonElement | null = null;
    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    function getFocusable(): HTMLElement[] {
      return Array.from(
        dialog.querySelectorAll<HTMLElement>(
          "button:not([disabled]), [tabindex]:not([tabindex='-1'])"
        )
      );
    }

    function updateNav(): void {
      prevBtn.disabled = current <= 0;
      nextBtn.disabled = current >= thumbBtns.length - 1;
      counterEl.textContent = `${current + 1} / ${thumbBtns.length}`;
    }

    function openAt(index: number): void {
      current = index;
      const btn = thumbBtns[index];

      // Load full-res image lazily — only now, not before opening.
      imgEl.src = btn.dataset.full ?? "";
      imgEl.alt = btn.dataset.alt ?? "";

      const cap = btn.dataset.caption;
      if (cap) {
        captEl.textContent = cap;
        captEl.removeAttribute("hidden");
      } else {
        captEl.setAttribute("hidden", "");
      }

      updateNav();

      // Show overlay — Tailwind's items-center/justify-center classes take effect once display=flex
      dialog.style.display = "flex";
      dialog.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";

      if (prefersReduced) dialog.style.animation = "none";

      closeBtn.focus();
    }

    function close(): void {
      dialog.style.display = "none";
      dialog.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
      imgEl.src = ""; // free full-res image memory

      const target = opener;
      current = -1;
      opener = null;
      target?.focus();
    }

    function navigate(dir: number): void {
      const next = current + dir;
      if (next >= 0 && next < thumbBtns.length) openAt(next);
    }

    // Open on thumbnail click
    thumbBtns.forEach((btn, i) => {
      btn.addEventListener("click", () => {
        opener = btn;
        openAt(i);
      });
    });

    // Controls
    closeBtn.addEventListener("click", close);
    prevBtn.addEventListener("click", () => navigate(-1));
    nextBtn.addEventListener("click", () => navigate(1));

    // Backdrop click closes (clicks on the content panel don't reach this handler)
    backdrop.addEventListener("click", close);

    // Keyboard navigation + focus trap
    dialog.addEventListener("keydown", (e: KeyboardEvent) => {
      if (e.key === "Escape")      { close();        return; }
      if (e.key === "ArrowLeft")   { navigate(-1);   return; }
      if (e.key === "ArrowRight")  { navigate(1);    return; }
      if (e.key === "Tab") {
        const focusable = getFocusable();
        if (!focusable.length) return;
        const first = focusable[0];
        const last  = focusable[focusable.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });

    // Touch swipe: left swipe → next, right swipe → prev
    let touchStartX = 0;
    dialog.addEventListener("touchstart", (e: TouchEvent) => {
      touchStartX = e.changedTouches[0].clientX;
    }, { passive: true });
    dialog.addEventListener("touchend", (e: TouchEvent) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) > 50) navigate(dx < 0 ? 1 : -1);
    }, { passive: true });
  });
</script>
